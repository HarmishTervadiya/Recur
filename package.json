{
  "name": "recur",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@recur/api",
    "dev:web": "turbo run dev --filter=@recur/web",
    "dev:keeper": "turbo run dev --filter=@recur/keeper",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "bun run --filter=@recur/db generate",
    "db:push": "bun run --filter=@recur/db db:push",
    "db:migrate": "bun run --filter=@recur/db migrate",
    "seed:localnet": "bun run --filter=@recur/keeper seed:localnet"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^20.12.0",
    "bs58": "^6.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.4.0"
  },
  "packageManager": "bun@1.1.0"
}
