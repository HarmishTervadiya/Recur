# ─── Solana ───────────────────────────────────────────────
# Cluster: localnet | devnet | mainnet-beta
SOLANA_CLUSTER=devnet
# RPC URL — if omitted, auto-resolved from SOLANA_CLUSTER.
# For localnet: http://127.0.0.1:8899
# For devnet:   https://api.devnet.solana.com (or your Helius/Triton URL)
# SOLANA_RPC_URL=
PROGRAM_ID=3pQTZk5w2AJLpB8zVLPxgU33PkyYZAfwgMoQzZRLoAxx

# For localnet: leave blank — `bun run demo:seed` sets this automatically.
# For devnet/mainnet: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recur

# ─── API ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# In production: must be at least 16 chars, no defaults provided.
# In development: auto-set if missing.
JWT_SECRET=change-me-in-production-min-16
JWT_REFRESH_SECRET=change-me-refresh-min-16
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
KEEPER_SECRET=localnet-keeper-secret

# ─── Keeper ───────────────────────────────────────────────
# Paste the JSON array from ~/.config/solana/id.json, or a base58 private key.
# On WSL:  cat ~/.config/solana/id.json
# On Win:  Get-Content "$env:USERPROFILE\.config\solana\id.json"
KEEPER_KEYPAIR=
KEEPER_BATCH_SIZE=20
API_URL=http://localhost:3001

# ─── Web ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PROGRAM_ID=3pQTZk5w2AJLpB8zVLPxgU33PkyYZAfwgMoQzZRLoAxx
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# NEXT_PUBLIC_SOLANA_RPC_URL=  # optional override

# ─── Demo (set automatically by demo:seed — do not edit) ──
# MINT_AUTHORITY_SECRET=
# DEMO_MERCHANT_SECRET=
# DEMO_PLAN_ID=
# DEMO_MERCHANT_ATA=
# DEMO_TREASURY_ATA=
# WATCH_SUBSCRIBER_ATA=
