{
  "name": "@recur/server",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/guard.js"
    },
    "./express": {
      "node": {
        "types": "./dist/express.d.ts",
        "default": "./dist/express.js"
      },
      "default": "./dist/guard.js"
    },
    "./next": {
      "node": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "default": "./dist/guard.js"
    },
    "./node": {
      "node": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "default": "./dist/guard.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "echo lint:server"
  },
  "dependencies": {
    "@recur/sdk": "*"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.12.0",
    "express": "^4.18.0",
    "typescript": "^5.4.0"
  }
}
